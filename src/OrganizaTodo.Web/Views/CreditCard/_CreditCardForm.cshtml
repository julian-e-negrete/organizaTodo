@model OrganizaTodo.Web.Models.ViewModels.CreditCardViewModel

@{
    var months = new[] { "Enero","Febrero","Marzo","Abril","Mayo","Junio",
                         "Julio","Agosto","Septiembre","Octubre","Noviembre","Diciembre" };
}

<div class="mb-3">
    <label asp-for="Description" class="form-label"></label>
    <input asp-for="Description" class="form-control" placeholder="Ej: Supermercado, Ropa, Netflix..." />
    <span asp-validation-for="Description" class="text-danger small"></span>
</div>

<div class="mb-3">
    <label asp-for="TotalAmount" class="form-label"></label>
    <div class="input-group">
        <span class="input-group-text">$</span>
        <input asp-for="TotalAmount" class="form-control" type="number" step="0.01" min="0" />
    </div>
    <span asp-validation-for="TotalAmount" class="text-danger small"></span>
</div>

<div class="row mb-3">
    <div class="col">
        <label asp-for="DueMonth" class="form-label fw-semibold">Mes a pagar</label>
        <select asp-for="DueMonth" class="form-select">
            @for (int i = 0; i < months.Length; i++)
            {
                <option value="@(i + 1)" selected="@(Model.DueMonth == i + 1)">@months[i]</option>
            }
        </select>
        <span asp-validation-for="DueMonth" class="text-danger small"></span>
    </div>
    <div class="col">
        <label asp-for="DueYear" class="form-label fw-semibold">Año</label>
        <input asp-for="DueYear" class="form-control" type="number" min="2020" max="2100" />
        <span asp-validation-for="DueYear" class="text-danger small"></span>
    </div>
</div>

<hr class="my-3" />
<p class="text-muted small mb-2">Cuotas (opcional — dejá en 1 para pago único)</p>

<div class="row">
    <div class="col mb-3">
        <label asp-for="Installments" class="form-label"></label>
        <input asp-for="Installments" class="form-control" type="number" min="1" max="72" />
        <span asp-validation-for="Installments" class="text-danger small"></span>
    </div>
    <div class="col mb-3">
        <label asp-for="InterestRate" class="form-label"></label>
        <div class="input-group">
            <input asp-for="InterestRate" class="form-control" type="number" step="0.01" min="0" max="100" />
            <span class="input-group-text">%</span>
        </div>
        <span asp-validation-for="InterestRate" class="text-danger small"></span>
    </div>
</div>

<div class="mb-3">
    <label asp-for="PurchaseDate" class="form-label text-muted">Fecha de compra</label>
    <input asp-for="PurchaseDate" class="form-control" type="date" />
    <span asp-validation-for="PurchaseDate" class="text-danger small"></span>
</div>
