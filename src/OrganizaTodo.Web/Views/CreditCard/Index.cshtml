@model IEnumerable<OrganizaTodo.Web.Models.Domain.CreditCardPurchase>
@{ ViewData["Title"] = "Tarjeta de Crédito"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>💳 Tarjeta de Crédito</h4>
    <a asp-action="Create" class="btn btn-primary btn-sm">+ Registrar compra</a>
</div>

@if (!Model.Any())
{
    <p class="text-muted">No hay compras registradas.</p>
}
else
{
    <table class="table table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Descripción</th><th>Total</th><th>Cuotas</th><th>Progreso</th><th>Cuota mensual</th><th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Description</td>
                    <td>$ @item.TotalAmount.ToString("N2")</td>
                    <td>@item.Installments</td>
                    <td>
                        <div class="progress" style="height:6px; width:80px;">
                            <div class="progress-bar bg-info"
                                 style="width:@(item.Installments > 0 ? (item.CurrentInstallment - 1) * 100 / item.Installments : 0)%"></div>
                        </div>
                        <small class="text-muted">@(item.CurrentInstallment)/@item.Installments</small>
                    </td>
                    <td class="fw-bold">$ @item.MonthlyInstallmentAmount.ToString("N2")</td>
                    <td class="text-end">
                        <form asp-action="AdvanceInstallment" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.Id" />
                            <button class="btn btn-sm btn-outline-success" title="Avanzar cuota">✓</button>
                        </form>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Editar</a>
                        <form asp-action="Delete" method="post" class="d-inline"
                              onsubmit="return confirm('¿Eliminar?')">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.Id" />
                            <button class="btn btn-sm btn-outline-danger">✕</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
        <tfoot>
            <tr class="table-secondary fw-bold">
                <td>Total mes</td><td></td><td></td><td></td>
                <td>$ @Model.Sum(x => x.MonthlyInstallmentAmount).ToString("N2")</td>
                <td></td>
            </tr>
        </tfoot>
    </table>
}
