@model OrganizaTodo.Web.Models.ViewModels.SavingsIndexViewModel
@{ ViewData["Title"] = "Ahorros"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>💰 Ahorros</h4>
    <a asp-action="Create" class="btn btn-primary btn-sm">+ Registrar ahorro</a>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card border-success h-100">
            <div class="card-body">
                <div class="text-muted small">Total acumulado</div>
                <div class="fs-4 fw-bold text-success">$ @Model.CumulativeTotal.ToString("N2")</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted small">Promedio mensual</div>
                <div class="fs-4 fw-bold">$ @Model.MonthlyAverage.ToString("N2")</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-info h-100">
            <div class="card-body">
                <div class="text-muted small">Proyección 6 meses</div>
                <div class="fs-4 fw-bold text-info">$ @Model.Projection6Months.ToString("N2")</div>
                <div class="text-muted" style="font-size:.7rem">si mantés el promedio</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-primary h-100">
            <div class="card-body">
                <div class="text-muted small">Proyección 12 meses</div>
                <div class="fs-4 fw-bold text-primary">$ @Model.Projection12Months.ToString("N2")</div>
                <div class="text-muted" style="font-size:.7rem">si mantés el promedio</div>
            </div>
        </div>
    </div>
</div>

@if (!Model.Items.Any())
{
    <p class="text-muted">No hay ahorros registrados aún.</p>
}
else
{
    <table class="table table-hover align-middle">
        <thead class="table-dark">
            <tr><th>Período</th><th>Monto</th><th>Notas</th><th></th></tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>
                        @(new DateTime(item.Year, item.Month, 1).ToString("MMMM yyyy", new System.Globalization.CultureInfo("es-AR")))
                        @if (item.IsInitialBalance)
                        {
                            <span class="badge bg-secondary ms-1">saldo inicial</span>
                        }
                    </td>
                    <td class="text-success fw-bold">$ @item.Amount.ToString("N2")</td>
                    <td class="text-muted">@item.Notes</td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Editar</a>
                        <form asp-action="Delete" method="post" class="d-inline"
                              onsubmit="return confirm('¿Eliminar este ahorro?')">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.Id" />
                            <button class="btn btn-sm btn-outline-danger">Eliminar</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
        <tfoot>
            <tr class="table-success fw-bold">
                <td>Total acumulado</td>
                <td>$ @Model.CumulativeTotal.ToString("N2")</td>
                <td colspan="2"></td>
            </tr>
        </tfoot>
    </table>
}
