@model OrganizaTodo.Web.Models.ViewModels.DashboardViewModel
@{ ViewData["Title"] = "Dashboard"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">📊 Balance – @Model.MonthName</h4>
    <div class="d-flex gap-2">
        <a asp-action="Index" asp-route-month="@(Model.Month == 1 ? 12 : Model.Month - 1)"
           asp-route-year="@(Model.Month == 1 ? Model.Year - 1 : Model.Year)"
           class="btn btn-sm btn-outline-secondary">‹ Anterior</a>
        <a asp-action="Index" asp-route-month="@(Model.Month == 12 ? 1 : Model.Month + 1)"
           asp-route-year="@(Model.Month == 12 ? Model.Year + 1 : Model.Year)"
           class="btn btn-sm btn-outline-secondary">Siguiente ›</a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card border-success h-100">
            <div class="card-body">
                <div class="text-muted small">Ingresos</div>
                <div class="fs-4 fw-bold text-success">$ @Model.Balance.TotalIncome.ToString("N2")</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-danger h-100">
            <div class="card-body">
                <div class="text-muted small">Total Pasivos</div>
                <div class="fs-4 fw-bold text-danger">$ @Model.Balance.TotalLiabilities.ToString("N2")</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-warning h-100">
            <div class="card-body">
                <div class="text-muted small">Otros Egresos</div>
                <div class="fs-4 fw-bold text-warning">$ @Model.Balance.TotalOtherExpenses.ToString("N2")</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card @(Model.Balance.RemainingBalance >= 0 ? "border-success" : "border-danger") h-100">
            <div class="card-body">
                <div class="text-muted small">Saldo Restante</div>
                <div class="fs-4 fw-bold @(Model.Balance.RemainingBalance >= 0 ? "text-success" : "text-danger")">
                    $ @Model.Balance.RemainingBalance.ToString("N2")
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header">Resumen del mes</div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0">
                    <tbody>
                        <tr>
                            <td>INGRESO DE CAPITAL</td>
                            <td class="text-end text-success fw-bold">$ @Model.Balance.TotalIncome.ToString("N2")</td>
                        </tr>
                        <tr>
                            <td class="ps-3 text-muted small">Servicios vivienda</td>
                            <td class="text-end text-muted small">-$ @Model.Balance.TotalServices.ToString("N2")</td>
                        </tr>
                        <tr>
                            <td class="ps-3 text-muted small">Tarjeta de crédito</td>
                            <td class="text-end text-muted small">-$ @Model.Balance.TotalCreditCard.ToString("N2")</td>
                        </tr>
                        <tr>
                            <td class="ps-3 text-muted small">Pasivos fijos</td>
                            <td class="text-end text-muted small">-$ @Model.Balance.TotalFixedLiabilities.ToString("N2")</td>
                        </tr>
                        <tr>
                            <td class="ps-3 text-muted small">Vehículos</td>
                            <td class="text-end text-muted small">-$ @Model.Balance.TotalVehicles.ToString("N2")</td>
                        </tr>
                        <tr class="table-danger">
                            <td><strong>PASIVOS TOTALES</strong></td>
                            <td class="text-end text-danger fw-bold">-$ @Model.Balance.TotalLiabilities.ToString("N2")</td>
                        </tr>
                        <tr>
                            <td>OTROS EGRESOS</td>
                            <td class="text-end text-warning fw-bold">-$ @Model.Balance.TotalOtherExpenses.ToString("N2")</td>
                        </tr>
                        <tr class="@(Model.Balance.RemainingBalance >= 0 ? "table-success" : "table-danger")">
                            <td><strong>SALDO RESTANTE</strong></td>
                            <td class="text-end fw-bold">$ @Model.Balance.RemainingBalance.ToString("N2")</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        @{
            var unpaidVehicleCosts = Model.VehiclesWithCosts.SelectMany(v =>
            {
                var costs = new List<(string label, decimal amount)>();
                if (!v.FuelPaid && v.MonthlyFuelCost > 0)
                    costs.Add(($"⛽ {v.Make} {v.Model} – Nafta", v.MonthlyFuelCost));
                if (!v.InsurancePaid && v.InsuranceMonthly.HasValue)
                    costs.Add(($"🛡️ {v.Make} {v.Model} – Seguro", v.InsuranceMonthly!.Value));
                if (!v.PatentePaid && v.MonthlyPatente > 0)
                    costs.Add(($"🪪 {v.Make} {v.Model} – Patente", v.MonthlyPatente));
                if (!v.MaintenancePaid && v.MonthlyOilChangeCost > 0)
                    costs.Add(($"🔧 {v.Make} {v.Model} – Mantenimiento", v.MonthlyOilChangeCost));
                return costs;
            }).ToList();

            var allPaid = !Model.UnpaidServices.Any() && !Model.UnpaidLiabilities.Any() && !unpaidVehicleCosts.Any();
        }
        <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>Servicios pendientes de pago</span>
                <div class="d-flex gap-1">
                    <a asp-controller="Housing" asp-action="Index" class="btn btn-sm btn-outline-primary">Vivienda</a>
                    <a asp-controller="Liabilities" asp-action="Index" class="btn btn-sm btn-outline-secondary">Pasivos</a>
                    <a asp-controller="Vehicles" asp-action="Index"
                       asp-route-month="@Model.Month" asp-route-year="@Model.Year"
                       class="btn btn-sm btn-outline-dark">Vehículos</a>
                </div>
            </div>
            <div class="card-body p-0">
                @if (allPaid)
                {
                    <p class="p-3 text-muted mb-0">✅ Todos los servicios están pagos.</p>
                }
                else
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var svc in Model.UnpaidServices)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <span>
                                    @svc.Name
                                    <span class="badge bg-primary ms-1">vivienda</span>
                                    @if (svc.DueDay > 0) { <span class="badge bg-secondary ms-1">vence día @svc.DueDay</span> }
                                </span>
                                <strong>$ @svc.Amount.ToString("N2")</strong>
                            </li>
                        }
                        @foreach (var lib in Model.UnpaidLiabilities)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <span>
                                    @lib.Name
                                    <span class="badge bg-warning text-dark ms-1">pasivo fijo</span>
                                    @if (lib.DueDay.HasValue) { <span class="badge bg-secondary ms-1">vence día @lib.DueDay</span> }
                                </span>
                                <strong>$ @lib.MonthlyAmount.ToString("N2")</strong>
                            </li>
                        }
                        @foreach (var (label, amount) in unpaidVehicleCosts)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <span>
                                    @label
                                    <span class="badge bg-dark ms-1">vehículo</span>
                                </span>
                                <strong>$ @amount.ToString("N2")</strong>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
</div>
