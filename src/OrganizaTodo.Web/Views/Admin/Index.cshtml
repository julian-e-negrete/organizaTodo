@model OrganizaTodo.Web.Models.Domain.AdminStats
@{ ViewData["Title"] = "Panel Admin"; }

<h4 class="mb-4">⚙️ Panel de Administración</h4>
<div class="row g-3">
    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <div class="display-5 fw-bold text-primary">@Model.TotalUsers</div>
                <div class="text-muted">Usuarios totales</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <div class="display-5 fw-bold text-success">@Model.ActiveUsers</div>
                <div class="text-muted">Usuarios activos</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <div class="display-5 fw-bold text-warning">@Model.AdminCount</div>
                <div class="text-muted">Administradores</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <div class="display-5 fw-bold text-info">@Model.TotalIncomeRecords</div>
                <div class="text-muted">Registros de ingreso</div>
            </div>
        </div>
    </div>
</div>
<div class="mt-4">
    <div class="card">
        <div class="card-body">
            <strong>Total ingresos acumulados (todos los usuarios):</strong>
            $ @Model.TotalIncomeAllUsers.ToString("N2")
        </div>
    </div>
</div>
<div class="mt-3">
    <a asp-action="Users" class="btn btn-outline-primary">Ver gestión de usuarios →</a>
</div>
