@model OrganizaTodo.Web.Models.ViewModels.IncomeViewModel
@{ ViewData["Title"] = "Registrar Ingreso"; }
<h4 class="mb-3">Registrar Ingreso</h4>
<div class="col-md-5">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <partial name="_IncomeForm" model="Model" />
        <div class="d-flex gap-2 mt-3">
            <button type="submit" class="btn btn-primary">Guardar</button>
            <a asp-action="Index" asp-route-month="@Model.Month" asp-route-year="@Model.Year" class="btn btn-outline-secondary">Cancelar</a>
        </div>
    </form>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
