@model OrganizaTodo.Web.Models.ViewModels.RecurringIncomeViewModel
@{ ViewData["Title"] = "Editar ingreso fijo"; }
<h4 class="mb-3">💼 Editar ingreso fijo</h4>
<div class="col-md-5">
    <form asp-action="EditRecurring" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <partial name="_RecurringIncomeForm" model="Model" />
        <div class="d-flex gap-2 mt-3">
            <button type="submit" class="btn btn-primary">Guardar</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
        </div>
    </form>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
