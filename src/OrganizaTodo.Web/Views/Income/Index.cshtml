@model OrganizaTodo.Web.Models.ViewModels.IncomeIndexViewModel
@{ ViewData["Title"] = "Ingresos"; int m = Model.Month; int y = Model.Year; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>💵 Ingresos – @(new DateTime(y,m,1).ToString("MMMM yyyy", new System.Globalization.CultureInfo("es-AR")))</h4>
    <div class="d-flex gap-2">
        <a asp-action="Index" asp-route-month="@(m==1?12:m-1)" asp-route-year="@(m==1?y-1:y)" class="btn btn-sm btn-outline-secondary">‹</a>
        <a asp-action="Index" asp-route-month="@(m==12?1:m+1)" asp-route-year="@(m==12?y+1:y)" class="btn btn-sm btn-outline-secondary">›</a>
        <a asp-action="Create" class="btn btn-primary btn-sm">+ Agregar</a>
    </div>
</div>

@if (!Model.Items.Any())
{
    <p class="text-muted">No hay ingresos registrados para este mes.</p>
}
else
{
    <table class="table table-hover align-middle">
        <thead class="table-dark">
            <tr><th>Descripción</th><th>Categoría</th><th>Monto</th><th></th></tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.Description</td>
                    <td><span class="badge bg-secondary">@(item.Category ?? "—")</span></td>
                    <td class="text-success fw-bold">$ @item.Amount.ToString("N2")</td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Editar</a>
                        <form asp-action="Delete" method="post" class="d-inline"
                              onsubmit="return confirm('¿Eliminar?')">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.Id" />
                            <input type="hidden" name="month" value="@m" />
                            <input type="hidden" name="year" value="@y" />
                            <button class="btn btn-sm btn-outline-danger">✕</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
        <tfoot>
            <tr class="table-success fw-bold">
                <td colspan="2">Total ingresos</td>
                <td>$ @Model.Items.Sum(x => x.Amount).ToString("N2")</td>
                <td></td>
            </tr>
        </tfoot>
    </table>
}
