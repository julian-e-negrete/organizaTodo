@model OrganizaTodo.Web.Models.ViewModels.HousingServiceViewModel
<div class="mb-3">
    <label asp-for="Name" class="form-label"></label>
    <input asp-for="Name" class="form-control" placeholder="Ej: Luz, Gas, Expensas" />
    <span asp-validation-for="Name" class="text-danger small"></span>
</div>
<div class="mb-3">
    <label asp-for="Amount" class="form-label"></label>
    <input asp-for="Amount" class="form-control" type="number" step="0.01" min="0" />
    <span asp-validation-for="Amount" class="text-danger small"></span>
</div>
<div class="mb-3">
    <label asp-for="DueDay" class="form-label"></label>
    <input asp-for="DueDay" class="form-control" type="number" min="1" max="31" />
    <span asp-validation-for="DueDay" class="text-danger small"></span>
</div>
<div class="mb-3">
    <label asp-for="Periodicity" class="form-label"></label>
    <select asp-for="Periodicity" class="form-select">
        <option value="MONTHLY">Mensual</option>
        <option value="BIMONTHLY">Bimestral</option>
    </select>
</div>
