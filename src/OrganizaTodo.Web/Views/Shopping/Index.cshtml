@model OrganizaTodo.Web.Models.ViewModels.ShoppingViewModel
@{ ViewData["Title"] = "Lista de Compras"; var list = Model.List; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>🛒 Lista de Compras – @(new DateTime(list.Year, list.Month, 1).ToString("MMMM yyyy", new System.Globalization.CultureInfo("es-AR")))</h4>
    <div class="d-flex gap-2">
        <a asp-action="Index" asp-route-month="@(list.Month==1?12:list.Month-1)"
           asp-route-year="@(list.Month==1?list.Year-1:list.Year)" class="btn btn-sm btn-outline-secondary">‹</a>
        <a asp-action="Index" asp-route-month="@(list.Month==12?1:list.Month+1)"
           asp-route-year="@(list.Month==12?list.Year+1:list.Year)" class="btn btn-sm btn-outline-secondary">›</a>
    </div>
</div>

@if (Model.IsOverBudget)
{
    <div class="alert alert-danger">
        ⚠️ El total estimado <strong>$ @Model.TotalEstimated.ToString("N2")</strong> supera tu saldo restante <strong>$ @Model.RemainingBalance.ToString("N2")</strong>.
    </div>
}
else if (Model.RemainingBalance > 0)
{
    <div class="alert alert-success">
        ✅ Saldo disponible: <strong>$ @Model.RemainingBalance.ToString("N2")</strong> | Estimado lista: <strong>$ @Model.TotalEstimated.ToString("N2")</strong>
        | Sobrante: <strong>$ @((Model.RemainingBalance - Model.TotalEstimated).ToString("N2"))</strong>
    </div>
}

<div class="row g-3">
    <div class="col-md-7">
        <div class="card">
            <div class="card-header">Ítems de la lista</div>
            <div class="card-body p-0">
                @if (!Model.Items.Any())
                {
                    <p class="p-3 text-muted mb-0">Todavía no agregaste productos.</p>
                }
                else
                {
                    <table class="table table-sm mb-0 align-middle">
                        <thead class="table-light">
                            <tr><th>Producto</th><th>Cant.</th><th>Precio est.</th><th>Super.</th><th>Prio.</th><th></th></tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td>@item.ProductName</td>
                                    <td>@item.Quantity</td>
                                    <td>@(item.EstimatedPrice.HasValue ? "$ " + item.EstimatedPrice.Value.ToString("N2") : "—")</td>
                                    <td><span class="badge bg-secondary">@(item.Supermarket ?? "—")</span></td>
                                    <td>
                                        <span class="badge @(item.Priority == 1 ? "bg-danger" : item.Priority == 3 ? "bg-secondary" : "bg-warning text-dark")">
                                            @item.PriorityLabel
                                        </span>
                                    </td>
                                    <td>
                                        <form asp-action="DeleteItem" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <input type="hidden" name="month" value="@list.Month" />
                                            <input type="hidden" name="year" value="@list.Year" />
                                            <button class="btn btn-sm btn-outline-danger">✕</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="table-secondary fw-bold">
                                <td colspan="2">Total estimado</td>
                                <td>$ @Model.TotalEstimated.ToString("N2")</td>
                                <td colspan="3"></td>
                            </tr>
                        </tfoot>
                    </table>
                }
            </div>
        </div>
    </div>
    <div class="col-md-5">
        <div class="card mb-3">
            <div class="card-header">Buscar producto (precios mock Coto/Carrefour)</div>
            <div class="card-body">
                <form asp-action="Index" method="get" class="d-flex gap-2">
                    <input type="hidden" name="month" value="@list.Month" />
                    <input type="hidden" name="year" value="@list.Year" />
                    <input name="q" value="@Model.SearchQuery" class="form-control" placeholder="Buscar..." />
                    <button type="submit" class="btn btn-outline-primary">🔍</button>
                </form>
                @if (Model.SearchResults.Any())
                {
                    <div class="mt-2">
                        @foreach (var p in Model.SearchResults)
                        {
                            <div class="border rounded p-2 mb-2 small">
                                <div class="fw-bold">@p.Name <span class="text-muted">(@p.Unit)</span></div>
                                <div class="d-flex gap-3 mt-1">
                                    <span>Coto: <strong>$ @(p.CotoPrice?.ToString("N2") ?? "—")</strong></span>
                                    <span>Carrefour: <strong>$ @(p.CarrefourPrice?.ToString("N2") ?? "—")</strong></span>
                                </div>
                                <div class="text-success">Más barato: <strong>@p.CheapestSupermarket $ @p.CheapestPrice?.ToString("N2")</strong></div>
                                <form asp-action="AddItem" method="post" class="mt-1">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="ShoppingListId" value="@list.Id" />
                                    <input type="hidden" name="ProductName" value="@p.Name" />
                                    <input type="hidden" name="EstimatedPrice" value="@p.CheapestPrice" />
                                    <input type="hidden" name="Supermarket" value="@p.CheapestSupermarket" />
                                    <input type="hidden" name="Priority" value="2" />
                                    <input type="hidden" name="Quantity" value="1" />
                                    <button class="btn btn-sm btn-success">+ Agregar</button>
                                </form>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
        <div class="card">
            <div class="card-header">Agregar ítem manualmente</div>
            <div class="card-body">
                <form asp-action="AddItem" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ShoppingListId" value="@list.Id" />
                    <div class="mb-2">
                        <input name="ProductName" class="form-control form-control-sm" placeholder="Producto *" required />
                    </div>
                    <div class="row g-1 mb-2">
                        <div class="col">
                            <input name="Quantity" type="number" min="1" value="1" class="form-control form-control-sm" placeholder="Cant." />
                        </div>
                        <div class="col">
                            <input name="EstimatedPrice" type="number" step="0.01" min="0" class="form-control form-control-sm" placeholder="Precio est." />
                        </div>
                    </div>
                    <div class="row g-1 mb-2">
                        <div class="col">
                            <select name="Supermarket" class="form-select form-select-sm">
                                <option value="">Supermercado</option>
                                <option value="Coto">Coto</option>
                                <option value="Carrefour">Carrefour</option>
                            </select>
                        </div>
                        <div class="col">
                            <select name="Priority" class="form-select form-select-sm">
                                <option value="1">Alta prioridad</option>
                                <option value="2" selected>Media</option>
                                <option value="3">Baja</option>
                            </select>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary btn-sm w-100">Agregar</button>
                </form>
            </div>
        </div>
    </div>
</div>
