@model OrganizaTodo.Web.Models.ViewModels.ShoppingViewModel
@{ ViewData["Title"] = "Lista de Compras"; var list = Model.List; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>🛒 Lista de Compras – @(new DateTime(list.Year, list.Month, 1).ToString("MMMM yyyy", new System.Globalization.CultureInfo("es-AR")))</h4>
    <div class="d-flex gap-2">
        <a asp-action="Index" asp-route-month="@(list.Month==1?12:list.Month-1)"
           asp-route-year="@(list.Month==1?list.Year-1:list.Year)" class="btn btn-sm btn-outline-secondary">‹</a>
        <a asp-action="Index" asp-route-month="@(list.Month==12?1:list.Month+1)"
           asp-route-year="@(list.Month==12?list.Year+1:list.Year)" class="btn btn-sm btn-outline-secondary">›</a>
    </div>
</div>

@if (Model.IsOverBudget)
{
    <div class="alert alert-danger">
        ⚠️ El total estimado <strong>$ @Model.TotalEstimated.ToString("N2")</strong> supera tu saldo restante <strong>$ @Model.RemainingBalance.ToString("N2")</strong>.
    </div>
}
else if (Model.RemainingBalance > 0)
{
    <div class="alert alert-success">
        ✅ Saldo disponible: <strong>$ @Model.RemainingBalance.ToString("N2")</strong> | Estimado lista: <strong>$ @Model.TotalEstimated.ToString("N2")</strong>
        | Sobrante: <strong>$ @((Model.RemainingBalance - Model.TotalEstimated).ToString("N2"))</strong>
    </div>
}

<div class="row g-3">
    <div class="col-md-7">
        <div class="card">
            <div class="card-header">Ítems de la lista</div>
            <div class="card-body p-0">
                @if (!Model.Items.Any())
                {
                    <p class="p-3 text-muted mb-0">Todavía no agregaste productos.</p>
                }
                else
                {
                    <table class="table table-sm mb-0 align-middle">
                        <thead class="table-light">
                            <tr><th>Producto</th><th>Cant.</th><th>Precio est.</th><th>Super.</th><th>Prio.</th><th></th></tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td>@item.ProductName</td>
                                    <td>@item.Quantity</td>
                                    <td>@(item.EstimatedPrice.HasValue ? "$ " + item.EstimatedPrice.Value.ToString("N2") : "—")</td>
                                    <td><span class="badge bg-secondary">@(item.Supermarket ?? "—")</span></td>
                                    <td>
                                        <span class="badge @(item.Priority == 1 ? "bg-danger" : item.Priority == 3 ? "bg-secondary" : "bg-warning text-dark")">
                                            @item.PriorityLabel
                                        </span>
                                    </td>
                                    <td>
                                        <form asp-action="DeleteItem" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <input type="hidden" name="month" value="@list.Month" />
                                            <input type="hidden" name="year" value="@list.Year" />
                                            <button class="btn btn-sm btn-outline-danger">✕</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="table-secondary fw-bold">
                                <td colspan="2">Total estimado</td>
                                <td>$ @Model.TotalEstimated.ToString("N2")</td>
                                <td colspan="3"></td>
                            </tr>
                        </tfoot>
                    </table>
                }
            </div>
        </div>
    </div>

    <div class="col-md-5">
        <div class="card mb-3">
            <div class="card-header">🔍 Buscar productos (Coto &amp; Carrefour)</div>
            <div class="card-body">
                <form asp-action="Index" method="get" class="d-flex gap-2 mb-2">
                    <input type="hidden" name="month" value="@list.Month" />
                    <input type="hidden" name="year" value="@list.Year" />
                    <input name="q" value="@Model.SearchQuery" class="form-control form-control-sm" placeholder="Buscar por nombre, marca…" />
                    <button type="submit" class="btn btn-outline-primary btn-sm">Buscar</button>
                </form>

                @if (Model.Categories.Any())
                {
                    <div class="d-flex flex-wrap gap-1">
                        <a asp-action="Index" asp-route-month="@list.Month" asp-route-year="@list.Year"
                           class="badge text-decoration-none @(string.IsNullOrEmpty(Model.SelectedCategory) && string.IsNullOrEmpty(Model.SearchQuery) ? "bg-dark" : "bg-secondary")">
                            Todos
                        </a>
                        @foreach (var cat in Model.Categories)
                        {
                            <a asp-action="Index" asp-route-month="@list.Month" asp-route-year="@list.Year"
                               asp-route-category="@cat"
                               class="badge text-decoration-none @(Model.SelectedCategory == cat ? "bg-primary" : "bg-secondary")">
                                @cat
                            </a>
                        }
                    </div>
                }
            </div>
        </div>

        @if (Model.SearchResults.Any())
        {
            <div class="card mb-3">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span>Resultados (@Model.SearchResults.Count())</span>
                    @if (!string.IsNullOrEmpty(Model.SelectedCategory))
                    {
                        <span class="badge bg-primary">@Model.SelectedCategory</span>
                    }
                </div>
                <div class="card-body p-2" style="max-height:480px;overflow-y:auto;">
                    @foreach (var p in Model.SearchResults)
                    {
                        var daysOld = (int)(DateTime.UtcNow - p.ScrapedAt).TotalDays;
                        <div class="border rounded p-2 mb-2 small @(p.Available ? "" : "opacity-50")">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <span class="fw-semibold">@p.Name</span>
                                    @if (!string.IsNullOrWhiteSpace(p.Brand))
                                    {
                                        <span class="text-muted ms-1">@p.Brand</span>
                                    }
                                </div>
                                <div class="d-flex gap-1 flex-shrink-0 ms-1">
                                    <span class="badge @(p.IsCoto ? "bg-success" : "bg-primary")">@p.Source</span>
                                    @if (p.IsOnPromo)
                                    {
                                        <span class="badge bg-warning text-dark" title="@p.Promo">PROMO</span>
                                    }
                                    @if (!p.Available)
                                    {
                                        <span class="badge bg-secondary">Sin stock</span>
                                    }
                                </div>
                            </div>
                            <div class="mt-1">
                                @if (p.ListPrice.HasValue && p.ListPrice > p.Price)
                                {
                                    <span class="text-decoration-line-through text-muted me-1">$ @p.ListPrice.Value.ToString("N2")</span>
                                }
                                <strong class="text-success">$ @p.Price.ToString("N2")</strong>
                                <span class="text-muted ms-2" style="font-size:.7rem;">act. hace @daysOld d.</span>
                            </div>
                            <form asp-action="AddItem" method="post" class="mt-1">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="ShoppingListId" value="@list.Id" />
                                <input type="hidden" name="ProductName" value="@p.Name" />
                                <input type="hidden" name="EstimatedPrice" value="@p.Price" />
                                <input type="hidden" name="Supermarket" value="@p.Source" />
                                <input type="hidden" name="Priority" value="2" />
                                <input type="hidden" name="Quantity" value="1" />
                                <button class="btn btn-sm btn-outline-success w-100">+ Agregar</button>
                            </form>
                        </div>
                    }
                </div>
            </div>
        }
        else if (!string.IsNullOrWhiteSpace(Model.SearchQuery) || !string.IsNullOrWhiteSpace(Model.SelectedCategory))
        {
            <div class="alert alert-secondary small">Sin resultados para la búsqueda actual.</div>
        }

        <div class="card">
            <div class="card-header">Agregar ítem manualmente</div>
            <div class="card-body">
                <form asp-action="AddItem" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ShoppingListId" value="@list.Id" />
                    <div class="mb-2">
                        <input name="ProductName" class="form-control form-control-sm" placeholder="Producto *" required />
                    </div>
                    <div class="row g-1 mb-2">
                        <div class="col">
                            <input name="Quantity" type="number" min="1" value="1" class="form-control form-control-sm" placeholder="Cant." />
                        </div>
                        <div class="col">
                            <input name="EstimatedPrice" type="number" step="0.01" min="0" class="form-control form-control-sm" placeholder="Precio est." />
                        </div>
                    </div>
                    <div class="row g-1 mb-2">
                        <div class="col">
                            <select name="Supermarket" class="form-select form-select-sm">
                                <option value="">Supermercado</option>
                                <option value="Coto">Coto</option>
                                <option value="Carrefour">Carrefour</option>
                            </select>
                        </div>
                        <div class="col">
                            <select name="Priority" class="form-select form-select-sm">
                                <option value="1">Alta prioridad</option>
                                <option value="2" selected>Media</option>
                                <option value="3">Baja</option>
                            </select>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary btn-sm w-100">Agregar</button>
                </form>
            </div>
        </div>
    </div>
</div>
