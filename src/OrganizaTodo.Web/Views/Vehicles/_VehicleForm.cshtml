@model OrganizaTodo.Web.Models.ViewModels.VehicleViewModel

<div class="row">
    <div class="col-md-4 mb-3">
        <label asp-for="Plate" class="form-label"></label>
        <input asp-for="Plate" class="form-control text-uppercase" placeholder="ABC123" />
        <span asp-validation-for="Plate" class="text-danger small"></span>
    </div>
    <div class="col-md-4 mb-3">
        <label asp-for="Make" class="form-label"></label>
        <input asp-for="Make" class="form-control" placeholder="Toyota" />
        <span asp-validation-for="Make" class="text-danger small"></span>
    </div>
    <div class="col-md-4 mb-3">
        <label asp-for="Model" class="form-label"></label>
        <input asp-for="Model" class="form-control" placeholder="Corolla" />
        <span asp-validation-for="Model" class="text-danger small"></span>
    </div>
</div>
<div class="row">
    <div class="col-md-4 mb-3">
        <label asp-for="Year" class="form-label"></label>
        <input asp-for="Year" class="form-control" type="number" min="1900" max="2100" />
        <span asp-validation-for="Year" class="text-danger small"></span>
    </div>
</div>

<hr class="my-3" />
<h6 class="text-secondary mb-3">⛽ Cálculo de combustible</h6>

<div class="row">
    <div class="col-md-4 mb-3">
        <label asp-for="WeeklyKm" class="form-label"></label>
        <div class="input-group">
            <input asp-for="WeeklyKm" id="weeklyKm" class="form-control" type="number" step="1" min="1" />
            <span class="input-group-text">km/sem</span>
        </div>
        <span asp-validation-for="WeeklyKm" class="text-danger small"></span>
        <div class="form-text">Km mensuales estimados: <strong id="monthlyKmDisplay">—</strong></div>
    </div>
    <div class="col-md-4 mb-3">
        <label asp-for="FuelEfficiencyKmL" class="form-label"></label>
        <div class="input-group">
            <input asp-for="FuelEfficiencyKmL" id="fuelEff" class="form-control" type="number" step="0.1" min="1" />
            <span class="input-group-text">km/L</span>
        </div>
        <span asp-validation-for="FuelEfficiencyKmL" class="text-danger small"></span>
    </div>
    <div class="col-md-4 mb-3">
        <label asp-for="FuelPricePerLiter" class="form-label"></label>
        <div class="input-group">
            <span class="input-group-text">$</span>
            <input asp-for="FuelPricePerLiter" id="fuelPrice" class="form-control" type="number" step="0.01" min="0" />
            <span class="input-group-text">/L</span>
        </div>
        <span asp-validation-for="FuelPricePerLiter" class="text-danger small"></span>
    </div>
</div>

<div class="mb-3">
    <button type="button" class="btn btn-outline-secondary btn-sm" id="btnFuelPrices">
        🔄 Cargar precios actuales (surtidores.com.ar)
    </button>
    <span id="fuelPricesStatus" class="ms-2 small text-muted"></span>
    <div id="fuelPricesPanel" class="mt-2 d-none">
        <div class="d-flex gap-2 flex-wrap">
            <button type="button" class="btn btn-sm btn-outline-primary selectFuel" data-fuel="super">
                Super: <strong id="priceSuper">—</strong> $/L
            </button>
            <button type="button" class="btn btn-sm btn-outline-success selectFuel" data-fuel="premium">
                Premium: <strong id="pricePremium">—</strong> $/L
            </button>
            <button type="button" class="btn btn-sm btn-outline-secondary selectFuel" data-fuel="gasoil">
                Gasoil: <strong id="priceGasoil">—</strong> $/L
            </button>
        </div>
        <div class="form-text mt-1">Hacé clic en el precio para usarlo.</div>
    </div>
</div>

<div class="alert alert-info py-2 px-3" id="fuelCostPreview">
    <span class="small">Costo mensual nafta estimado: <strong id="monthlyFuelCostDisplay">—</strong></span>
</div>

<hr class="my-3" />
<h6 class="text-secondary mb-3">🛡️ Otros costos mensuales</h6>

<div class="row">
    <div class="col-md-6 mb-3">
        <label asp-for="InsuranceMonthly" class="form-label"></label>
        <div class="input-group">
            <span class="input-group-text">$</span>
            <input asp-for="InsuranceMonthly" id="insurance" class="form-control" type="number" step="0.01" min="0" />
        </div>
        <span asp-validation-for="InsuranceMonthly" class="text-danger small"></span>
    </div>
    <div class="col-md-6 mb-3">
        <label asp-for="PatenteAnnual" class="form-label"></label>
        <div class="input-group">
            <span class="input-group-text">$</span>
            <input asp-for="PatenteAnnual" id="patente" class="form-control" type="number" step="0.01" min="0" />
        </div>
        <span asp-validation-for="PatenteAnnual" class="text-danger small"></span>
        <div class="form-text">Cuota mensual: <strong id="monthlyPatenteDisplay">—</strong></div>
    </div>
</div>

<hr class="my-3" />
<h6 class="text-secondary mb-3">🔧 Mantenimiento / Cambio de aceite</h6>

<div class="row">
    <div class="col-md-6 mb-3">
        <label asp-for="OilChangeIntervalKm" class="form-label"></label>
        <div class="input-group">
            <input asp-for="OilChangeIntervalKm" id="oilInterval" class="form-control" type="number" step="500" min="1000" />
            <span class="input-group-text">km</span>
        </div>
        <span asp-validation-for="OilChangeIntervalKm" class="text-danger small"></span>
        <div class="form-text">Ej: 10000 para cambio cada 10.000 km</div>
    </div>
    <div class="col-md-6 mb-3">
        <label asp-for="OilChangeCostEstimate" class="form-label"></label>
        <div class="input-group">
            <span class="input-group-text">$</span>
            <input asp-for="OilChangeCostEstimate" id="oilCost" class="form-control" type="number" step="0.01" min="0" />
        </div>
        <span asp-validation-for="OilChangeCostEstimate" class="text-danger small"></span>
        <div class="form-text">Costo promedio de cada cambio de aceite</div>
    </div>
</div>
<div class="row">
    <div class="col-md-6 mb-3">
        <label asp-for="LastOilChangeDate" class="form-label"></label>
        <input name="LastOilChangeDate" id="LastOilChangeDate" class="form-control" type="date"
               value="@(Model.LastOilChangeDate?.ToString("yyyy-MM-dd"))" />
        <span asp-validation-for="LastOilChangeDate" class="text-danger small"></span>
    </div>
    <div class="col-md-6 mb-3">
        <label asp-for="LastOilChangeKm" class="form-label"></label>
        <div class="input-group">
            <input asp-for="LastOilChangeKm" class="form-control" type="number" step="1" min="0" />
            <span class="input-group-text">km</span>
        </div>
        <span asp-validation-for="LastOilChangeKm" class="text-danger small"></span>
        <div class="form-text">Odómetro al momento del último cambio</div>
    </div>
</div>

<div class="alert alert-secondary py-2 px-3 small" id="oilChangePreview" style="display:none">
    🔧 Próximo cambio estimado: <strong id="nextOilMonthDisplay">—</strong>
    &nbsp;·&nbsp; Costo: <strong id="oilCostDisplay">—</strong>
</div>

<div class="alert alert-success py-2 px-3">
    <span class="small">Costo mensual recurrente estimado: <strong id="totalMonthlyCostDisplay">—</strong></span>
    <div class="text-muted small" id="oilCostNote" style="display:none">
        (El cambio de aceite se sumará en el mes en que corresponda)
    </div>
</div>

<script>
(function () {
    const weeklyKmEl  = document.getElementById('weeklyKm');
    const fuelEffEl   = document.getElementById('fuelEff');
    const fuelPriceEl = document.getElementById('fuelPrice');
    const insuranceEl = document.getElementById('insurance');
    const patenteEl   = document.getElementById('patente');
    const oilIntEl    = document.getElementById('oilInterval');
    const oilCostEl   = document.getElementById('oilCost');
    const oilDateEl   = document.getElementById('LastOilChangeDate');

    const monthNames = ['', 'Enero','Febrero','Marzo','Abril','Mayo','Junio',
                        'Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];

    function n(el) { return parseFloat(el?.value) || 0; }

    function recalc() {
        const wkm       = n(weeklyKmEl);
        const monthlyKm = wkm * 52 / 12;
        document.getElementById('monthlyKmDisplay').textContent =
            wkm > 0 ? monthlyKm.toFixed(0) + ' km/mes' : '—';

        const fuel = n(fuelEffEl) > 0 && n(fuelPriceEl) > 0
            ? monthlyKm / n(fuelEffEl) * n(fuelPriceEl) : 0;
        document.getElementById('monthlyFuelCostDisplay').textContent =
            fuel > 0 ? '$ ' + fuel.toFixed(2) : '—';

        const patente = n(patenteEl) / 12;
        document.getElementById('monthlyPatenteDisplay').textContent =
            n(patenteEl) > 0 ? '$ ' + patente.toFixed(2) : '—';

        const oilInterval = n(oilIntEl);
        const oilCost     = n(oilCostEl);
        const oilPreview  = document.getElementById('oilChangePreview');
        const oilNote     = document.getElementById('oilCostNote');

        if (oilInterval > 0 && wkm > 0 && oilDateEl?.value) {
            const lastDate   = new Date(oilDateEl.value + 'T00:00:00');
            const daysToNext = oilInterval / wkm * 7;
            const nextDue    = new Date(lastDate.getTime() + daysToNext * 86400000);
            const m          = nextDue.getMonth() + 1;
            const y          = nextDue.getFullYear();
            document.getElementById('nextOilMonthDisplay').textContent = monthNames[m] + ' ' + y;
            document.getElementById('oilCostDisplay').textContent = oilCost > 0 ? '$ ' + oilCost.toFixed(2) : 'no especificado';
            oilPreview.style.display = '';
            oilNote.style.display = oilCost > 0 ? '' : 'none';
        } else {
            oilPreview.style.display = 'none';
            oilNote.style.display = 'none';
        }

        // Total recurrente = fuel + seguro + patente (sin aceite — aparece solo en el mes que corresponde)
        const total = fuel + n(insuranceEl) + patente;
        document.getElementById('totalMonthlyCostDisplay').textContent =
            total > 0 ? '$ ' + total.toFixed(2) : '—';
    }

    [weeklyKmEl, fuelEffEl, fuelPriceEl, insuranceEl, patenteEl, oilIntEl, oilCostEl, oilDateEl]
        .forEach(el => el?.addEventListener('input', recalc));
    recalc();

    // Fuel price loader
    const btnFuelPrices = document.getElementById('btnFuelPrices');
    let fuelData = null;
    btnFuelPrices?.addEventListener('click', async () => {
        const status = document.getElementById('fuelPricesStatus');
        status.textContent = 'Cargando…';
        btnFuelPrices.disabled = true;
        try {
            const r = await fetch('/Vehicles/GetFuelPrices');
            fuelData = await r.json();
            if (fuelData.error) { status.textContent = fuelData.error; return; }
            document.getElementById('priceSuper').textContent   = fuelData.super;
            document.getElementById('pricePremium').textContent = fuelData.premium;
            document.getElementById('priceGasoil').textContent  = fuelData.gasoil;
            document.getElementById('fuelPricesPanel').classList.remove('d-none');
            status.textContent = 'Actualizado: ' + fuelData.fetchedAt;
        } catch { status.textContent = 'Error al obtener precios.'; }
        finally { btnFuelPrices.disabled = false; }
    });

    document.querySelectorAll('.selectFuel').forEach(btn => {
        btn.addEventListener('click', () => {
            if (!fuelData) return;
            const val = btn.dataset.fuel === 'super'   ? fuelData.super
                      : btn.dataset.fuel === 'premium' ? fuelData.premium
                      : fuelData.gasoil;
            if (fuelPriceEl) { fuelPriceEl.value = val; recalc(); }
        });
    });
})();
</script>
