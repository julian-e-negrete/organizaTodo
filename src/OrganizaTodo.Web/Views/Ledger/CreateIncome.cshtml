@model OrganizaTodo.Web.Models.ViewModels.LedgerIncomeViewModel
@{ ViewData["Title"] = "Nuevo Ingreso"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>💵 Nuevo Ingreso</h4>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">‹ Volver</a>
</div>

<div class="card">
    <div class="card-body">
        <form asp-action="CreateIncome" method="post">
            @Html.AntiForgeryToken()
            <partial name="_IncomeForm" />
            <div class="mt-4">
                <button type="submit" class="btn btn-success">Registrar ingreso</button>
                <a asp-action="Index" class="btn btn-outline-secondary ms-2">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
