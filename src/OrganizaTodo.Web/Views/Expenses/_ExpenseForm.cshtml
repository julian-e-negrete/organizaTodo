@model OrganizaTodo.Web.Models.ViewModels.OtherExpenseViewModel
<div class="mb-3">
    <label asp-for="Description" class="form-label"></label>
    <input asp-for="Description" class="form-control" placeholder="Ej: Compra dólares, Ahorro, Neumáticos" />
    <span asp-validation-for="Description" class="text-danger small"></span>
</div>
<div class="mb-3">
    <label asp-for="Amount" class="form-label"></label>
    <input asp-for="Amount" class="form-control" type="number" step="0.01" min="0" />
    <span asp-validation-for="Amount" class="text-danger small"></span>
</div>
<div class="row">
    <div class="col mb-3">
        <label class="form-label">Mes</label>
        <select asp-for="Month" class="form-select">
            @for (var i = 1; i <= 12; i++)
            {
                <option value="@i" selected="@(Model.Month == i)">@(new DateTime(2000, i, 1).ToString("MMMM", new System.Globalization.CultureInfo("es-AR")))</option>
            }
        </select>
    </div>
    <div class="col mb-3">
        <label asp-for="Year" class="form-label">Año</label>
        <input asp-for="Year" class="form-control" type="number" min="2000" max="2100" />
    </div>
</div>

@if (ViewBag.Vehicles != null)
{
    <div class="mb-3">
        <label asp-for="VehicleId" class="form-label">🚗 Vehículo (opcional)</label>
        <select asp-for="VehicleId" asp-items="ViewBag.Vehicles" class="form-select">
            <option value="">— Sin vehículo —</option>
        </select>
        <div class="form-text">Vinculá este egreso a un vehículo para verlo en el historial del vehículo.</div>
    </div>
}
