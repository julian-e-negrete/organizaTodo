@model OrganizaTodo.Web.Models.ViewModels.AssetPurchaseViewModel

<div class="row g-3">
    <div class="col-md-6">
        <label class="form-label fw-semibold">Tipo de activo</label>
        <select asp-for="AssetType" class="form-select" id="assetType">
            <option value="USD">💵 Dólar (USD)</option>
            <option value="ACCION">📈 Acción</option>
            <option value="CRYPTO">₿ Crypto</option>
            <option value="OTRO">📦 Otro</option>
        </select>
        <span asp-validation-for="AssetType" class="text-danger small"></span>
    </div>

    <div class="col-md-6">
        <label class="form-label fw-semibold">Fecha de compra</label>
        <input asp-for="PurchaseDate" type="date" class="form-control" />
        <span asp-validation-for="PurchaseDate" class="text-danger small"></span>
    </div>

    <div class="col-md-6" id="exchangeTypeGroup">
        <label class="form-label fw-semibold">Tipo de cambio</label>
        <div class="input-group">
            <select asp-for="ExchangeType" class="form-select" id="exchangeTypeSelect">
                <option value="">— Seleccioná —</option>
                <option value="oficial">Oficial</option>
                <option value="blue">Blue</option>
                <option value="bolsa">Bolsa (MEP)</option>
                <option value="contadoconliqui">Contado con Liqui</option>
                <option value="mayorista">Mayorista</option>
                <option value="cripto">Cripto</option>
                <option value="tarjeta">Tarjeta</option>
            </select>
            <button type="button" class="btn btn-outline-info btn-sm px-2" id="fetchRatesBtn">
                Cotización actual
            </button>
        </div>
    </div>

    <div class="col-md-3" id="quantityGroup">
        <label class="form-label fw-semibold" id="quantityLabel">Cantidad</label>
        <input asp-for="Quantity" type="number" step="0.0001" class="form-control"
               id="quantityInput" placeholder="Ej: 100" />
        <span asp-validation-for="Quantity" class="text-danger small"></span>
    </div>

    <div class="col-md-3" id="unitPriceGroup">
        <label class="form-label fw-semibold">Precio unitario (ARS)</label>
        <input asp-for="UnitPriceArs" type="number" step="0.01" class="form-control"
               id="unitPriceInput" placeholder="Ej: 1415.00" />
        <span asp-validation-for="UnitPriceArs" class="text-danger small"></span>
    </div>

    <div class="col-md-6">
        <label class="form-label fw-semibold">Total ARS</label>
        <div class="input-group">
            <span class="input-group-text">$</span>
            <input asp-for="TotalArs" type="number" step="0.01" class="form-control"
                   id="totalArsInput" placeholder="0.00" />
        </div>
        <div class="form-text">Se calcula si ingresás cantidad × precio unitario.</div>
        <span asp-validation-for="TotalArs" class="text-danger small"></span>
    </div>

    <div class="col-12">
        <label class="form-label fw-semibold">Notas</label>
        <input asp-for="Notes" class="form-control" placeholder="Opcional" maxlength="500" />
        <span asp-validation-for="Notes" class="text-danger small"></span>
    </div>
</div>

<div id="ratesPanel" class="mt-3" style="display:none">
    <div class="card border-info">
        <div class="card-header bg-info bg-opacity-10 fw-semibold text-info small">
            💱 Cotización del dólar (en vivo)
        </div>
        <div class="card-body p-0">
            <table class="table table-sm table-hover mb-0">
                <thead class="table-secondary">
                    <tr><th>Mercado</th><th>Compra</th><th>Venta</th><th></th></tr>
                </thead>
                <tbody id="ratesBody"></tbody>
            </table>
        </div>
    </div>
</div>

@if (Model.Id == 0)
{
    <hr class="my-4" />
    <h6 class="text-muted mb-3">Vínculos automáticos</h6>
    <p class="text-muted small mb-3">Registrá automáticamente un egreso y/o un ahorro vinculados a esta compra.</p>

    <div class="card mb-3">
        <div class="card-body">
            <div class="form-check mb-2">
                <input asp-for="CreateExpense" class="form-check-input" type="checkbox" id="createExpenseCheck" />
                <label class="form-check-label fw-semibold" for="createExpenseCheck">
                    💸 Registrar como Egreso
                </label>
            </div>
            <div id="expenseFields" class="row g-2">
                <div class="col-md-6">
                    <label class="form-label small">Descripción (opcional)</label>
                    <input asp-for="ExpenseDescription" class="form-control form-control-sm"
                           placeholder="Se genera automáticamente si está vacío" maxlength="200" />
                </div>
                <div class="col-md-3">
                    <label class="form-label small">Mes</label>
                    <select asp-for="ExpenseMonth" class="form-select form-select-sm">
                        @for (int i = 1; i <= 12; i++)
                        {
                            <option value="@i">@(new DateTime(2000, i, 1).ToString("MMMM", new System.Globalization.CultureInfo("es-AR")))</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small">Año</label>
                    <input asp-for="ExpenseYear" type="number" class="form-control form-control-sm" min="2020" max="2099" />
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <div class="form-check mb-2">
                <input asp-for="CreateSaving" class="form-check-input" type="checkbox" id="createSavingCheck" />
                <label class="form-check-label fw-semibold" for="createSavingCheck">
                    🏦 Registrar como Ahorro
                </label>
            </div>
            <div id="savingFields" class="row g-2">
                <div class="col-md-6">
                    <label class="form-label small">Notas del ahorro (opcional)</label>
                    <input asp-for="SavingNotes" class="form-control form-control-sm"
                           placeholder="Ej: USD comprados en mayo" maxlength="200" />
                </div>
                <div class="col-md-3">
                    <label class="form-label small">Mes</label>
                    <select asp-for="SavingMonth" class="form-select form-select-sm">
                        @for (int i = 1; i <= 12; i++)
                        {
                            <option value="@i">@(new DateTime(2000, i, 1).ToString("MMMM", new System.Globalization.CultureInfo("es-AR")))</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small">Año</label>
                    <input asp-for="SavingYear" type="number" class="form-control form-control-sm" min="2020" max="2099" />
                </div>
            </div>
        </div>
    </div>
}
